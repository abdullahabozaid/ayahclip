# Pexels API key — enables the stock photo/video background library.
# Get one free at https://www.pexels.com/api/. Server-side only (never exposed).
PEXELS_API_KEY=

# Optional: absolute URL to the ~131 MB Arabic ASR model (.onnx). Leave blank to
# serve it same-origin from public/asr/fastconformer_ar_ctc_q8.onnx. Set this to
# CORS-enabled external storage (S3/R2/CDN) for hosts with a static file-size
# limit. Must be reachable cross-origin (Access-Control-Allow-Origin).
NEXT_PUBLIC_ASR_MODEL_URL=
