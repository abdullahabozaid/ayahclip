# Pexels API key — enables the stock photo/video background library.
# Get one free at https://www.pexels.com/api/. Server-side only (never exposed).
PEXELS_API_KEY=

# Optional server-side OpenAI key for AI-shaped TikTok/Reels/Shorts captions.
# Without it, the same UI returns safe, deterministic editorial options.
OPENAI_API_KEY=
# Cost-sensitive current model by default. Override only with a Responses API model.
OPENAI_CAPTION_MODEL=gpt-5.6-luna

# Optional server-side Stripe key for the Support checkout route.
# Without it, the support page remains available and checkout returns a safe
# "not configured" message. Never expose this as NEXT_PUBLIC_*.
STRIPE_SECRET_KEY=

# Canonical public origin used in metadata and social share cards.
NEXT_PUBLIC_SITE_URL=https://ayahclip.vercel.app

# URL to the ~131 MB Arabic ASR model (.onnx). Local development can leave this
# blank to use public/asr/fastconformer_ar_ctc_q8.onnx. Vercel production uses
# /api/asr-model as a same-origin bridge; replace it with CORS-enabled R2/S3/CDN
# storage before broad traffic to avoid paying application-host bandwidth.
NEXT_PUBLIC_ASR_MODEL_URL=
