# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/test-results/
/tmp/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# playwright mcp artifacts
.playwright-mcp/

# local QA / test screenshots (kept out of the repo)
/*.png
/scripts/*.png

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Large ASR model (host on CORS-enabled CDN/bucket for deploy; download for dev)
public/asr/*.onnx

# Local video assets (backgrounds + exports)
/videos/
/public/videos/aesthetic/
.env*.local
.superpowers/
.superdesign/tmp/

# Xcode local build products
/ios/DerivedData/
**/xcuserdata/
*.xcuserstate
