{
  "name": "ayahclip",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:accessibility": "playwright test e2e/accessibility.spec.ts --project=chromium --workers=1",
    "test:google-chrome": "GOOGLE_CHROME=1 playwright test --project=google-chrome",
    "test:production-google": "PLAYWRIGHT_BASE_URL=https://ayahclip.vercel.app GOOGLE_CHROME=1 playwright test e2e/google-readiness.spec.ts e2e/production-smoke.spec.ts",
    "test:production-performance": "PERFORMANCE_BUDGET=1 PLAYWRIGHT_BASE_URL=https://ayahclip.vercel.app GOOGLE_CHROME=1 playwright test e2e/performance-budget.spec.ts --project=google-chrome --workers=1 --repeat-each=3",
    "test:production-resilience": "PLAYWRIGHT_BASE_URL=https://ayahclip.vercel.app GOOGLE_CHROME=1 playwright test e2e/throttled-first-load.spec.ts e2e/offline-export-readiness.spec.ts e2e/import-failure-readiness.spec.ts e2e/text-edge-export.spec.ts --project=google-chrome --workers=1",
    "test:export-matrix": "EXPORT_STRESS=1 playwright test e2e/device-export-readiness.spec.ts e2e/long-export-readiness.spec.ts",
    "test:detection": "tsx scripts/test-detection.ts",
    "test:alignment": "node scripts/test-alignment-matrix.mjs",
    "test:recognition": "node scripts/test-recognition-matrix.mjs",
    "test:mixed-speech": "tsx scripts/evaluate-mixed-speech-recognition.ts",
    "benchmark:recognition-corpus": "tsx scripts/evaluate-recognition-corpus.ts",
    "benchmark:prepare-quranlab": "tsx scripts/prepare-quranlab-benchmark.ts",
    "benchmark:fixtures": "node scripts/fetch-alignment-fixtures.mjs",
    "check:reciter-sources": "tsx scripts/check-reciter-sources.ts",
    "check:stock-media": "tsx scripts/check-stock-media.ts",
    "audit:mp3quran-provider": "tsx scripts/audit-mp3quran-provider.ts",
    "analytics:report": "tsx scripts/product-analytics-report.ts"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@huggingface/transformers": "^3.8.1",
    "idb-keyval": "^6.2.4",
    "mp4-muxer": "^5.2.2",
    "next": "16.2.10",
    "onnxruntime-web": "^1.26.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.15"
    }
  }
}
